# Avenly Web — Apache config dla Hostingera
# Plik tworzy reguły cache, kompresji i bezpieczeństwa dla static export Next.js

# ============================================================
# 1. CACHE — kluczowe dla wydajności
# ============================================================

<IfModule mod_headers.c>

  # Next.js chunks i media z hashem w nazwie — cache forever (1 rok, immutable)
  # Bezpieczne bo zmiana zawartości = nowy hash = nowy URL
  <FilesMatch "\.(js|css|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Obrazy WebP/PNG/JPG/SVG/ICO — 30 dni (mogą się zmieniać, np. portfolio)
  <FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # Czcionki — 1 rok (rzadko się zmieniają)
  <FilesMatch "\.(ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML — krótki cache (1h), bo treści mogą się aktualizować po rebuildzie
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>

  # Manifest i robots — 1 dzień
  <FilesMatch "(manifest\.webmanifest|robots\.txt|sitemap\.xml)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

</IfModule>

# ============================================================
# 2. KOMPRESJA — Brotli > Gzip (Hostinger wspiera oba)
# ============================================================

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE application/font-woff2 image/svg+xml
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css
  AddOutputFilterByType BROTLI_COMPRESS application/javascript application/json
</IfModule>

# ============================================================
# 3. NAGŁÓWKI BEZPIECZEŃSTWA — bonus SEO (trust signals)
# ============================================================

<IfModule mod_headers.c>
  # Wymusza HTTPS przez rok (cofnij jeśli kiedyś przejdziesz na HTTP)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # Zapobiega clickjacking (iframe od innych stron)
  Header set X-Frame-Options "SAMEORIGIN"

  # MIME-type sniffing protection
  Header set X-Content-Type-Options "nosniff"

  # Referrer policy — nie wysyła pełnego URL do innych domen
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions Policy — wyłącza nieużywane API
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
</IfModule>

# ============================================================
# 4. PRETTY URLS — obsługa trailingSlash z Next.js
# ============================================================

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Wymusza HTTPS (na wypadek jakby ktoś wszedł przez http://)
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Usuwa .html z URL (Next robi /blog/post/index.html — chcemy /blog/post/)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)\.html$ /$1/ [R=301,L]

  # ────────────────────────────────────────────────────────────
  # 301 REDIRECTS — restrukturyzacja oferty stron-www (2026-05-28)
  # Stare slugi → nowe, czytelne dla klienta. Zachowuje SEO rankings.
  # ────────────────────────────────────────────────────────────
  RewriteRule ^uslugi/strony-www/profesjonalna-strona-firmowa/?$ /uslugi/strony-www/strona-firmowa/ [R=301,L]
  RewriteRule ^uslugi/strony-www/strona-wordpress/?$ /uslugi/strony-www/strona-firmowa/ [R=301,L]
  RewriteRule ^uslugi/strony-www/dedykowane-strony-www/?$ /uslugi/strony-www/strona-szyta-na-miare/ [R=301,L]
  RewriteRule ^uslugi/strony-www/aplikacje-webowe/?$ /uslugi/strony-www/system-crm/ [R=301,L]
  RewriteRule ^uslugi/strony-www/sklepy-internetowe/?$ /uslugi/strony-www/sklep-internetowy/ [R=301,L]
  RewriteRule ^uslugi/strony-www/sklep/?$ /uslugi/strony-www/sklep-internetowy/ [R=301,L]
</IfModule>

# ============================================================
# 5. CUSTOM 404 PAGE
# ============================================================

ErrorDocument 404 /404.html
